{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/**",
              "components/buddy/**",
              "components/moments/**",
              "components/parent/**",
              "components/progress/**",
              "components/reading/**",
              "components/recap/**",
              "components/shelf/**",
              "components/speech/**",
              "components/transitions/**",
              "components/writing/**",
              "ui_kits/home/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Young Serif|Alegreya|Caveat|Inter))/i]",
        "message": "Font not provided by the design system. Available: Young Serif, Alegreya, Caveat, Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='AskCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:question|micActive|onMic|width|style|key|ref|className|style|children)$/]",
        "message": "<AskCard> doesn't accept that prop. Declared props: question, micActive, onMic, width, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BookCover'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|pigment|width|art|progress|authored|sketch|beacon|onOpen|style|key|ref|className|style|children)$/]",
        "message": "<BookCover> doesn't accept that prop. Declared props: title, pigment, width, art, progress, authored, sketch, beacon, onOpen, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BookCover'] > JSXAttribute[name.name='pigment'] > Literal[value!=/^(?:marigold|butter|terracotta|sage|river|teal|berry|dusk|bark|plum)$/]",
        "message": "<BookCover> pigment must be one of 'marigold' | 'butter' | 'terracotta' | 'sage' | 'river' | 'teal' | 'berry' | 'dusk' | 'bark' | 'plum'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BreatheCircle'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|pigment|running|style|key|ref|className|style|children)$/]",
        "message": "<BreatheCircle> doesn't accept that prop. Declared props: size, pigment, running, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BreatheCircle'] > JSXAttribute[name.name='pigment'] > Literal[value!=/^(?:teal|dusk|sage|river|plum)$/]",
        "message": "<BreatheCircle> pigment must be one of 'teal' | 'dusk' | 'sage' | 'river' | 'plum'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Buddy'] > JSXAttribute > JSXIdentifier[name!=/^(?:pose|size|breathing|style|key|ref|className|style|children)$/]",
        "message": "<Buddy> doesn't accept that prop. Declared props: pose, size, breathing, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Buddy'] > JSXAttribute[name.name='pose'] > Literal[value!=/^(?:idle|listening|pointing|celebrating)$/]",
        "message": "<Buddy> pose must be one of 'idle' | 'listening' | 'pointing' | 'celebrating'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChoiceCards'] > JSXAttribute > JSXIdentifier[name!=/^(?:choices|onPick|picked|size|style|key|ref|className|style|children)$/]",
        "message": "<ChoiceCards> doesn't accept that prop. Declared props: choices, onPick, picked, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Endpaper'] > JSXAttribute > JSXIdentifier[name!=/^(?:pigment|motif|loading|children|style|key|ref|className|style|children)$/]",
        "message": "<Endpaper> doesn't accept that prop. Declared props: pigment, motif, loading, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Endpaper'] > JSXAttribute[name.name='pigment'] > Literal[value!=/^(?:marigold|butter|terracotta|sage|river|teal|berry|dusk|bark|plum)$/]",
        "message": "<Endpaper> pigment must be one of 'marigold' | 'butter' | 'terracotta' | 'sage' | 'river' | 'teal' | 'berry' | 'dusk' | 'bark' | 'plum'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Endpaper'] > JSXAttribute[name.name='motif'] > Literal[value!=/^(?:star|moon|leaf|boat)$/]",
        "message": "<Endpaper> motif must be one of 'star' | 'moon' | 'leaf' | 'boat'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Medallion'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|pigment|size|motif|style|key|ref|className|style|children)$/]",
        "message": "<Medallion> doesn't accept that prop. Declared props: label, pigment, size, motif, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Medallion'] > JSXAttribute[name.name='pigment'] > Literal[value!=/^(?:marigold|terracotta|sage|river|teal|berry|plum)$/]",
        "message": "<Medallion> pigment must be one of 'marigold' | 'terracotta' | 'sage' | 'river' | 'teal' | 'berry' | 'plum'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ParentSurface'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|children|width|style|key|ref|className|style|children)$/]",
        "message": "<ParentSurface> doesn't accept that prop. Declared props: title, children, width, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ReadingPage'] > JSXAttribute > JSXIdentifier[name!=/^(?:art|text|highlightIndex|autoHighlight|highlightMs|micActive|onMic|onNext|pageLabel|width|style|key|ref|className|style|children)$/]",
        "message": "<ReadingPage> doesn't accept that prop. Declared props: art, text, highlightIndex, autoHighlight, highlightMs, micActive, onMic, onNext, pageLabel, width, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ReadingSuns'] > JSXAttribute > JSXIdentifier[name!=/^(?:count|size|sill|style|key|ref|className|style|children)$/]",
        "message": "<ReadingSuns> doesn't accept that prop. Declared props: count, size, sill, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RecapStrip'] > JSXAttribute > JSXIdentifier[name!=/^(?:panels|panelWidth|style|key|ref|className|style|children)$/]",
        "message": "<RecapStrip> doesn't accept that prop. Declared props: panels, panelWidth, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpeechBalloon'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|tail|speaking|maxWidth|style|key|ref|className|style|children)$/]",
        "message": "<SpeechBalloon> doesn't accept that prop. Declared props: children, variant, tail, speaking, maxWidth, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpeechBalloon'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:calm|bouncy)$/]",
        "message": "<SpeechBalloon> variant must be one of 'calm' | 'bouncy'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpeechBalloon'] > JSXAttribute[name.name='tail'] > Literal[value!=/^(?:left|right|none)$/]",
        "message": "<SpeechBalloon> tail must be one of 'left' | 'right' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StarWord'] > JSXAttribute > JSXIdentifier[name!=/^(?:word|pin|rotate|width|style|key|ref|className|style|children)$/]",
        "message": "<StarWord> doesn't accept that prop. Declared props: word, pin, rotate, width, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StarWord'] > JSXAttribute[name.name='pin'] > Literal[value!=/^(?:berry|river|marigold|sage|teal|plum)$/]",
        "message": "<StarWord> pin must be one of 'berry' | 'river' | 'marigold' | 'sage' | 'teal' | 'plum'."
      },
      {
        "selector": "JSXOpeningElement[name.name='WritingMoment'] > JSXAttribute > JSXIdentifier[name!=/^(?:words|inkPigment|width|wordMs|style|key|ref|className|style|children)$/]",
        "message": "<WritingMoment> doesn't accept that prop. Declared props: words, inkPigment, width, wordMs, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='WritingMoment'] > JSXAttribute[name.name='inkPigment'] > Literal[value!=/^(?:river|berry|sage|plum|teal)$/]",
        "message": "<WritingMoment> inkPigment must be one of 'river' | 'berry' | 'sage' | 'plum' | 'teal'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
