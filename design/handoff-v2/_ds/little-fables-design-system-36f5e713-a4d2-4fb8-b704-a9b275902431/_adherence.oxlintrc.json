{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/learning/**",
              "components/parent/**",
              "components/story-world/**",
              "ui_kits/composer/**",
              "ui_kits/story-world/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fredoka|Quicksand|Inter|Baloo 2))/i]",
        "message": "Font not provided by the design system. Available: Fredoka, Quicksand, Inter, Baloo 2."
      },
      {
        "selector": "JSXOpeningElement[name.name='AskBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:question|praise|hint|skill|state|listening|onMicTap|standalone|style|key|ref|className|style|children)$/]",
        "message": "<AskBubble> doesn't accept that prop. Declared props: question, praise, hint, skill, state, listening, onMicTap, standalone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AskBubble'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:question|praise|hint)$/]",
        "message": "<AskBubble> state must be one of 'question' | 'praise' | 'hint'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|fallback|size|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, fallback, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|secondary|outline|ghost|destructive|link)$/]",
        "message": "<Button> variant must be one of 'default' | 'secondary' | 'outline' | 'ghost' | 'destructive' | 'link'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:default|sm|lg|icon)$/]",
        "message": "<Button> size must be one of 'default' | 'sm' | 'lg' | 'icon'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|children|footer|padded|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, description, children, footer, padded, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChoiceOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|emoji|keywords|key|ref|className|style|children)$/]",
        "message": "<ChoiceOption> doesn't accept that prop. Declared props: label, emoji, keywords."
      },
      {
        "selector": "JSXOpeningElement[name.name='MagicButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:emoji|children|sub|onClick|size|tone|style|key|ref|className|style|children)$/]",
        "message": "<MagicButton> doesn't accept that prop. Declared props: emoji, children, sub, onClick, size, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MagicButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|sm)$/]",
        "message": "<MagicButton> size must be one of 'lg' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MagicButton'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:coral|butter)$/]",
        "message": "<MagicButton> tone must be one of 'coral' | 'butter'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SceneStage'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|bg|emojis|text|highlightWord|children|style|key|ref|className|style|children)$/]",
        "message": "<SceneStage> doesn't accept that prop. Declared props: image, bg, emojis, text, highlightWord, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StoryCover'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|image|emoji|bg|meta|badge|editMode|onDelete|onClick|style|key|ref|className|style|children)$/]",
        "message": "<StoryCover> doesn't accept that prop. Declared props: title, image, emoji, bg, meta, badge, editMode, onDelete, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='VocabStar'] > JSXAttribute > JSXIdentifier[name!=/^(?:word|active|onTap|style|key|ref|className|style|children)$/]",
        "message": "<VocabStar> doesn't accept that prop. Declared props: word, active, onTap, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
